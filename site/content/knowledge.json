                                                               "title":  "NVR",
                                                               "children":  [
                                                                                {
                                                                                    "id":  "troubleshooting-nvr-time",
                                                                                    "title":  "NVR Time Issue",
                                                                                    "summary":  "Symptoms and suggestions for NVR time reset or 1970 time issues.",
                                                                                    "keywords":  [
                                                                                                     "nvr",
                                                                                                     "time",
                                                                                                     "1970",
                                                                                                     "cmos",
                                                                                                     "battery",
                                                                                                     "chip"
                                                                                                 ],
                                                                                    "sections":  [
                                                                                                     {
                                                                                                         "title":  "Symptoms and Suggestions",
                                                                                                         "html":  "\u003ctable\u003e\u003cthead\u003e\u003ctr\u003e\u003cth\u003eSymptom\u003c/th\u003e\u003cth\u003eSuggestion\u003c/th\u003e\u003c/tr\u003e\u003c/thead\u003e\u003ctbody\u003e\u003ctr\u003e\u003ctd\u003eThe time can be saved manually, but changes to 1970 after reboot.\u003c/td\u003e\u003ctd\u003eTry replacing the CMOS battery.\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003eThe time cannot be saved correctly and always stays at 1970.\u003c/td\u003e\u003ctd\u003eThe chip may be aging.\u003c/td\u003e\u003c/tr\u003e\u003c/tbody\u003e\u003c/table\u003e"
                                                                                                     }
                                                                                                 ]
                                                                                }
                                                                            ],
